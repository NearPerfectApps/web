---
import '../styles/global.css';

interface Props {
  title?: string;
  bodyClass?: string;
}
const { title = 'NearPerfectApps', bodyClass = 'overflow-hidden w-screen h-screen' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="NearPerfectApps — Small team, bold ideas, real apps." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
